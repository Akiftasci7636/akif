["Akifftasc7"]
<!DOCTYPE html>
<html lang="tr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AKO İnşaat & Dekorasyon | Modern Yaşam Alanları</title>
    <!-- Google Fonts (Montserrat & Playfair Display) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;1,400&display=swap" rel="stylesheet">
    <!-- FontAwesome İkonları -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Montserrat', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                    },
                    colors: {
                        gold: {
                            DEFAULT: '#D4AF37',
                            light: '#F3E5AB',
                            dark: '#AA7C11'
                        },
                        charcoal: '#121212',
                        cardBg: '#1A1A1A'
                    }
                }
            }
        }
    </script>
    <style>
        .hero-bg {
            background-linear: linear-gradient(rgba(18, 18, 18, 0.85), rgba(18, 18, 18, 0.95));
            background-image: url('https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
        }
        .text-gradient-gold {
            background: linear-gradient(135deg, #BF953F 0%, #FCF6BA 25%, #B38728 50%, #FBF5B7 75%, #AA771C 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>
<body class="bg-charcoal text-gray-300 font-sans antialiased">

    <!-- 1. NAVIGASYON BAR (HEADER) -->
    <header class="fixed w-full top-0 z-50 bg-charcoal/90 backdrop-blur-md border-b border-neutral-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
            <!-- Logo -->
            <a href="#" class="flex items-center gap-3 group">
                <div class="h-10 w-10 rounded-lg bg-gradient-to-br from-amber-500 to-amber-700 flex items-center justify-center font-extrabold text-xl text-black shadow-lg">
                    A
                </div>
                <div>
                    <span class="text-xl font-black tracking-widest text-white block">AKO İNŞAAT</span>
                    <span class="text-[9px] font-bold tracking-[0.3em] text-amber-500 uppercase block -mt-1">DEKORASYON</span>
                </div>
            </a>
            
            <!-- Masaüstü Menü -->
            <nav class="hidden md:flex items-center gap-8 text-xs font-semibold uppercase tracking-wider">
                <a href="#home" class="text-white hover:text-amber-500 transition-colors">Anasayfa</a>
                <a href="#about" class="hover:text-white transition-colors">Biz Kimiz</a>
                <a href="#services" class="hover:text-white transition-colors">Hizmetler</a>
                <a href="#projects" class="hover:text-white transition-colors">Projelerimiz</a>
                <a href="#contact" class="bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 text-black px-5 py-2.5 rounded-lg transition-all shadow-md">İletişime Geç</a>
            </nav>

            <!-- Mobil Menü Butonu -->
            <button onclick="toggleMobileMenu()" class="md:hidden text-white text-2xl focus:outline-none">
                <i id="menu-icon" class="fa-solid fa-bars"></i>
            </button>
        </div>

        <!-- Mobil Menü Listesi -->
        <div id="mobile-menu" class="hidden md:hidden bg-charcoal border-b border-neutral-800 px-6 py-6 space-y-4 text-sm font-medium uppercase tracking-wide">
            <a href="#home" onclick="toggleMobileMenu()" class="block text-white">Anasayfa</a>
            <a href="#about" onclick="toggleMobileMenu()" class="block text-gray-400 hover:text-white">Biz Kimiz</a>
            <a href="#services" onclick="toggleMobileMenu()" class="block text-gray-400 hover:text-white">Hizmetler</a>
            <a href="#projects" onclick="toggleMobileMenu()" class="block text-gray-400 hover:text-white">Projelerimiz</a>
            <a href="#contact" onclick="toggleMobileMenu()" class="block text-amber-500 font-semibold">İletişim</a>
        </div>
    </header>

    <!-- 2. HERO / GİRİŞ ALANI -->
    <section id="home" class="hero-bg min-h-screen flex items-center relative pt-20">
        <!-- Karartma Overlay -->
        <div class="absolute inset-0 bg-black/80 z-0"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full py-20 lg:py-32">
            <div class="max-w-3xl space-y-6">
                <span class="text-xs font-bold tracking-[0.4em] text-amber-500 uppercase bg-amber-500/10 px-3 py-1.5 rounded border border-amber-500/20 inline-block">
                    Geleceği İnşa Ediyoruz
                </span>
                <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight leading-none">
                    Sağlam Temeller, <br>
                    <span class="text-gradient-gold">Estetik Dokunuşlar.</span>
                </h1>
                <p class="text-base sm:text-lg text-neutral-400 font-light max-w-xl">
                    AKO İnşaat & Dekorasyon olarak, modern mimari çizgileri lüks dekorasyon çözümleriyle birleştiriyor; yaşam alanlarınıza değer katıyoruz.
                </p>
                <div class="pt-4 flex flex-wrap gap-4">
                    <a href="#projects" class="bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 text-black text-sm font-bold px-8 py-3.5 rounded-lg shadow-lg shadow-amber-950/40 transition-all">
                        Projelerimizi İnceleyin
                    </a>
                    <a href="#contact" class="border border-neutral-700 hover:border-amber-500 text-white text-sm font-semibold px-8 py-3.5 rounded-lg transition-all bg-white/5 backdrop-blur-sm">
                        Teklif Alın
                    </a>
                </div>
            </div>
        </div>

        <!-- Aşağı Kaydır İkonu -->
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-neutral-500 text-center animate-bounce z-10 hidden sm:block">
            <a href="#about" class="text-xs tracking-widest uppercase block mb-2">Keşfet</a>
            <i class="fa-solid fa-chevron-down text-lg"></i>
        </div>
    </section>

    <!-- 3. HAKKIMIZDA (BİZ KİMİZ) -->
    <section id="about" class="py-24 bg-neutral-950">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- Görsel Alanı -->
            <div class="relative">
                <div class="border-2 border-amber-500/30 absolute -inset-3 rounded-2xl transform translate-x-3 translate-y-3 z-0"></div>
                <img src="https://images.unsplash.com/photo-1541888946425-d81bb19240f5?auto=format&fit=crop&w=800&q=80" alt="İnşaat Sahası" class="rounded-2xl shadow-2xl relative z-10 border border-neutral-800 w-full object-cover h-[350px] sm:h-[450px]">
            </div>
            
            <!-- Metin Alanı -->
            <div class="space-y-6">
                <div class="space-y-2">
                    <span class="text-xs font-bold text-amber-500 uppercase tracking-widest">AKO Kurumsal</span>
                    <h2 class="text-3xl font-bold text-white tracking-tight">Güven ve Kalitenin Buluştuğu Nokta</h2>
                </div>
                <p class="text-neutral-400 text-sm sm:text-base leading-relaxed">
                    AKO İnşaat & Dekorasyon Limited Şirketi, kuruluşundan bu yana yapı sektöründe yenilikçi yaklaşımları ve ödün vermediği kalite standartlarıyla öne çıkmaktadır. Kaba inşaattan en ince iç mimari detaylara kadar, her aşamada titizlikle çalışıyoruz.
                </p>
                <!-- Kısa İstatistikler -->
                <div class="grid grid-cols-2 gap-6 pt-4 border-t border-neutral-800">
                    <div>
                        <h4 class="text-3xl font-extrabold text-white text-gradient-gold">%100</h4>
                        <p class="text-xs text-neutral-400 mt-1 uppercase tracking-wider">Müşteri Memnuniyeti</p>
                    </div>
                    <div>
                        <h4 class="text-3xl font-extrabold text-white text-gradient-gold">Zamanında</h4>
                        <p class="text-xs text-neutral-400 mt-1 uppercase tracking-wider">Anahtar Teslim</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 4. HİZMETLERİMİZ -->
    <section id="services" class="py-24 bg-charcoal">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-xl mx-auto mb-16 space-y-2">
                <span class="text-xs font-bold text-amber-500 uppercase tracking-widest">Uzmanlık Alanlarımız</span>
                <h2 class="text-3xl font-bold text-white tracking-tight">Size Neler Sunuyoruz?</h2>
                <p class="text-xs sm:text-sm text-neutral-500">A'dan Z'ye tüm yapı süreçlerinizde profesyonel ekiplerimizle hizmetinizdeyiz.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Kart 1 -->
                <div class="bg-cardBg border border-neutral-800 p-8 rounded-2xl hover:border-amber-500/50 transition-all group duration-300">
                    <div class="h-12 w-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-500 text-xl mb-6 group-hover:bg-amber-500 group-hover:text-black transition-all">
                        <i class="fa-solid fa-helmet-safety"></i>
                    </div>
                    <h3 class="text-lg font-bold text-white mb-3">Anahtar Teslim İnşaat</h3>
                    <p class="text-xs sm:text-sm text-neutral-400 leading-relaxed">Projelerinizi kaba inşaat safhasından alıp, modern şehircilik standartlarına uygun şekilde sıfırdan inşa ediyor ve eksiksiz teslim ediyoruz.</p>
                </div>

                <!-- Kart 2 -->
                <div class="bg-cardBg border border-neutral-800 p-8 rounded-2xl hover:border-amber-500/50 transition-all group duration-300">
                    <div class="h-12 w-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-500 text-xl mb-6 group-hover:bg-amber-500 group-hover:text-black transition-all">
                        <i class="fa-solid fa-couch"></i>
                    </div>
                    <h3 class="text-lg font-bold text-white mb-3">İç Mimari & Dekorasyon</h3>
                    <p class="text-xs sm:text-sm text-neutral-400 leading-relaxed">Ev, ofis ya da ticari alanlarınızı modern akımlara uygun, işlevsel ve lüks dekorasyon detayları ile baştan tasarlıyor, uyguluyoruz.</p>
                </div>

                <!-- Kart 3 -->
                <div class="bg-cardBg border border-neutral-800 p-8 rounded-2xl hover:border-amber-500/50 transition-all group duration-300">
                    <div class="h-12 w-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-500 text-xl mb-6 group-hover:bg-amber-500 group-hover:text-black transition-all">
                        <i class="fa-solid fa-compass-drafting"></i>
                    </div>
                    <h3 class="text-lg font-bold text-white mb-3">Projelendirme & Danışmanlık</h3>
                    <p class="text-xs sm:text-sm text-neutral-400 leading-relaxed">Uygulama öncesinde mekân planlaması, bütçelendirme, malzeme seçimi ve estetik tasarım danışmanlığı ile riskleri sıfıra indiriyoruz.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- 5. ÖNE ÇIKAN PROJELER -->
    <section id="projects" class="py-24 bg-neutral-950">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end mb-12 gap-4">
                <div>
                    <span class="text-xs font-bold text-amber-500 uppercase tracking-widest">Portfolyo</span>
                    <h2 class="text-3xl font-bold text-white tracking-tight">Öne Çıkan Projelerimiz</h2>
                </div>
                <span class="text-xs text-neutral-500 font-medium">AKO İmzası Taşıyan Yapılar</span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Proje 1 -->
                <div class="group relative overflow-hidden rounded-xl border border-neutral-800 shadow-lg aspect-[4/3]">
                    <img src="https://images.unsplash.com/photo-1613490493576-7fde63acd811?auto=format&fit=crop&w=600&q=80" alt="Lüks Villa" class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-500">
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent flex flex-col justify-end p-6">
                        <span class="text-[10px] font-bold text-amber-500 uppercase tracking-widest">Premium Villa</span>
                        <h4 class="text-lg font-bold text-white mt-1">AKO Safir Konakları</h4>
                    </div>
                </div>

                <!-- Proje 2 -->
                <div class="group relative overflow-hidden rounded-xl border border-neutral-800 shadow-lg aspect-[4/3]">
                    <img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?auto=format&fit=crop&w=600&q=80" alt="Modern Ofis" class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-500">
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent flex flex-col justify-end p-6">
                        <span class="text-[10px] font-bold text-amber-500 uppercase tracking-widest">İç Mimari / Ofis</span>
                        <h4 class="text-lg font-bold text-white mt-1">Nexus İş Merkezi</h4>
                    </div>
                </div>

                <!-- Proje 3 -->
                <div class="group relative overflow-hidden rounded-xl border border-neutral-800 shadow-lg aspect-[4/3]">
                    <img src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&w=600&q=80" alt="Rezidans Daire" class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-500">
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent flex flex-col justify-end p-6">
                        <span class="text-[10px] font-bold text-amber-500 uppercase tracking-widest">Dekorasyon / Rezidans</span>
                        <h4 class="text-lg font-bold text-white mt-1">Zekeriyaköy Loft Daire</h4>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 6. İLETİŞİM ALANI -->
    <section id="contact" class="py-24 bg-charcoal">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
            
            <!-- Bilgi Kutusu -->
            <div class="lg:col-span-5 space-y-8">
                <div>
                    <span class="text-xs font-bold text-amber-500 uppercase tracking-widest">Bize Ulaşın</span>
                    <h2 class="text-3xl font-bold text-white tracking-tight mt-1">Projenizi Konuşalım</h2>
                    <p class="text-xs sm:text-sm text-neutral-400 mt-3 leading-relaxed">
                        Hayalinizdeki yapıyı veya dekorasyon fikrini hayata geçirmek için ilk adımı atın. Formu doldurun, uzman ekibimiz en kısa sürede size dönüş sağlasın.
                    </p>
                </div>

                <div class="space-y-4 text-sm">
                    <div class="flex items-center gap-4">
                        <div class="h-10 w-10 rounded-lg bg-neutral-900 border border-neutral-800 flex items-center justify-center text-amber-500">
                            <i class="fa-solid fa-phone"></i>
                        </div>
                        <div>
                            <p class="text-xs text-neutral-500 uppercase font-semibold">Telefon</p>
                            <p class="text-white font-medium text-xs sm:text-sm">[Telefon Numarasını Buraya Ekleyebilirsiniz]</p>
                        </div>
                    </div>

                    <div class="flex items-center gap-4">
                        <div class="h-10 w-10 rounded-lg bg-neutral-900 border border-neutral-800 flex items-center justify-center text-amber-500">
                            <i class="fa-solid fa-envelope"></i>
                        </div>
                        <div>
                            <p class="text-xs text-neutral-500 uppercase font-semibold">E-Posta</p>
                            <p class="text-white font-medium text-xs sm:text-sm">[E-Posta Adresinizi Buraya Ekleyebilirsiniz]</p>
                        </div>
                    </div>

                    <div class="flex items-center gap-4">
                        <div class="h-10 w-10 rounded-lg bg-neutral-900 border border-neutral-800 flex items-center justify-center text-amber-500">
                            <i class="fa-solid fa-location-dot"></i>
                        </div>
                        <div>
                            <p class="text-xs text-neutral-500 uppercase font-semibold">Merkez Ofis</p>
                            <p class="text-white font-medium text-xs sm:text-sm">İstanbul, Türkiye</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- İletişim Formu -->
            <div class="lg:col-span-7 bg-cardBg border border-neutral-800 p-6 sm:p-8 rounded-2xl w-full">
                <form onsubmit="handleFormSubmit(event)" class="space-y-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] font-bold uppercase text-neutral-400 tracking-wider mb-1">Adınız Soyadınız</label>
                            <input type="text" required class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-4 py-2.5 text-sm text-white focus:outline-none focus:border-amber-500 transition-colors">
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold uppercase text-neutral-400 tracking-wider mb-1">Telefon Numaranız</label>
                            <input type="tel" required class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-4 py-2.5 text-sm text-white focus:outline-none focus:border-amber-500 transition-colors">
                        </div>
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-neutral-400 tracking-wider mb-1">E-Posta Adresiniz</label>
                        <input type="email" required class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-4 py-2.5 text-sm text-white focus:outline-none focus:border-amber-500 transition-colors">
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-neutral-400 tracking-wider mb-1">Mesajınız / Proje Detayları</label>
                        <textarea rows="4" required class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-4 py-2.5 text-sm text-white focus:outline-none focus:border-amber-500 transition-colors placeholder-neutral-600" placeholder="İstediğiniz uygulama veya inşaat alanı hakkında kısa bilgi veriniz..."></textarea>
                    </div>
                    <button type="submit" class="w-full bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 text-black font-bold py-3 px-4 rounded-lg text-sm transition-all shadow-lg shadow-amber-950/30">
                        Mesajı Gönder
                    </button>
                </form>
            </div>

        </div>
    </section>

    <!-- 7. FOOTER / ALT BİLGİ -->
    <footer class="bg-neutral-950 border-t border-neutral-900 py-12 text-xs text-neutral-500">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row justify-between items-center gap-6">
            <div class="flex items-center gap-3">
                <div class="h-8 w-8 rounded bg-amber-500 flex items-center justify-center font-bold text-black text-sm">
                    A
                </div>
                <p>© 2026 AKO İnşaat Dekorasyon Ltd. Şti. Tüm Hakları Saklıdır.</p>
            </div>
            <div class="flex gap-6 text-neutral-400">
                <a href="#home" class="hover:text-amber-500 transition-colors">Yeniden Yukarı Çık</a>
            </div>
        </div>
    </footer>

    <!-- JavaScript - Menü Kontrolleri ve İşlevler -->
    <script>
        // Mobil Menü Aç/Kapat Fonksiyonu
        function toggleMobileMenu() {
            const menu = document.getElementById('mobile-menu');
            const icon = document.getElementById('menu-icon');
            
            if (menu.classList.contains('hidden')) {
                menu.classList.remove('hidden');
                icon.className = "fa-solid fa-xmark";
            } else {
                menu.classList.add('hidden');
                icon.className = "fa-solid fa-bars";
            }
        }

        // Demo Form Gönderim Bildirimi
        function handleFormSubmit(event) {
            event.preventDefault();
            alert("Teşekkürler! Mesajınız simüle edildi. AKO İnşaat sistemi şu an aktiftir.");
            event.target.reset();
        }
    </script>
</body>
</html>
